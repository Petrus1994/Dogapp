generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS & AUTH ────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   Boolean   @default(false)
  passwordHash    String?   // null for Apple / Google users
  authProvider    String    @default("email")   // "email" | "apple" | "google"
  appleUserId     String?   @unique
  googleUserId    String?   @unique
  marketingOptIn  Boolean   @default(false)
  displayName     String?
  scenarioType    String?
  onboardingDone  Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  sessions                  Session[]
  emailVerificationTokens   EmailVerificationToken[]
  passwordResetTokens       PasswordResetToken[]
  dogs                      Dog[]
  breedSelectionProfiles    BreedSelectionProfile[]
  trainingPlans             TrainingPlan[]
  aiConversations           AiConversation[]
  subscription              Subscription?
  subscriptionEvents        SubscriptionEvent[]
  aiUsage                   AiUsage[]
  referralCode              String?           @unique  // human-readable invite code e.g. "LUNA4K8A"
  referralsGiven            Referral[]        @relation("ReferrerRelation")
  referralReceived          Referral?         @relation("ReferredRelation")
  referralRewards           ReferralReward[]
  futureDogProfile          FutureDogProfile?
  notificationTokens        NotificationToken[]
  notificationJobs          NotificationJob[]
  userProgress              UserProgress?
  userChallenges            UserChallenge[]
  auditLogs                 AuditLog[]

  @@map("users")
}

model Session {
  id            String    @id @default(cuid())
  userId        String
  refreshToken  String    @unique
  deviceName    String?
  ipAddress     String?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  revokedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─── DOGS ────────────────────────────────────────────────────────────────────

model Dog {
  id              String    @id @default(cuid())
  userId          String
  name            String
  gender          String
  ageGroup        String
  birthDate       DateTime?
  breed           String?
  isBreedUnknown  Boolean   @default(false)
  size            String?
  activityLevel         String
  activityLevelOverride String?   // per-dog personality modifier, overrides breed default
  coatColor             String?   // drives avatar appearance
  photoUrl        String?
  isActive        Boolean   @default(true)
  isWorkingDog    Boolean   @default(false)  // hunting, protection, service, sport — adjusts plan tone
  lifestyleNote   String?                    // free-text owner context ("trained for protection work")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  issues                DogIssue[]
  memory                DogMemory?
  behaviorDimensions    BehaviorDimension[]
  behaviorScoreHistory  BehaviorScoreHistory[]
  recurringTriggers     RecurringTrigger[]
  dailyLogs             DailyLog[]
  feedingLogs           FeedingLog[]
  walkLogs              WalkLog[]
  playLogs              PlayLog[]
  trainingSessionLogs   TrainingSessionLog[]
  toiletEvents          ToiletEvent[]
  behaviorEvents        BehaviorEvent[]
  userNotes             UserNote[]
  extractedSignals      ExtractedNoteSignal[]
  aiAdviceHistory       AiAdviceHistory[]
  dailyInsights         DailyInsight[]
  shareSummaries        ShareSummary[]
  adaptivePattern       AdaptivePattern?
  dailyRoutines         DailyRoutine[]
  trainingPlans         TrainingPlan[]
  taskFeedback          TaskFeedback[]
  notificationJobs      NotificationJob[]
  avatar                DogAvatar?
  visualTraits          DogVisualTraits?
  avatarGenerationJobs  DogAvatarGenerationJob[]
  avatarStateHistory    DogAvatarStateHistory[]

  @@map("dogs")
}

// ─── AVATAR SYSTEM ───────────────────────────────────────────────────────────

model DogAvatar {
  id                  String    @id @default(cuid())
  dogId               String    @unique
  userId              String
  masterAvatarUrl     String?
  thumbnailUrl        String?
  currentAgeStage     String    @default("puppy")
  avatarVersion       Int       @default(1)
  provider            String?
  generationStatus    String    @default("pending")
  regenerationCount   Int       @default(0)
  maxRegenerations    Int       @default(2)
  referencePhotoUrls  String[]
  identitySeed        String?   // stores traits hash for consistency across evolutions
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@map("dog_avatars")
}

model DogVisualTraits {
  id                   String   @id @default(cuid())
  dogId                String   @unique
  userProvidedBreed    String?
  breedGuessFromImage  String?
  coatColor            String?
  coatPattern          String?
  coatLength           String?
  coatTexture          String?
  earType              String?
  muzzleShape          String?
  noseColor            String?
  eyeColor             String?
  tailType             String?
  bodyShape            String?
  sizeClass            String?
  ageStage             String?
  distinctiveMarks     String?
  confidenceScore      Decimal? @db.Decimal(4, 3)
  warnings             String[]
  rawAnalysisJson      Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@map("dog_visual_traits")
}

model DogAvatarGenerationJob {
  id              String    @id @default(cuid())
  dogId           String
  userId          String
  status          String    @default("queued")  // queued | processing | completed | failed
  provider        String?
  inputPhotoUrls  String[]
  promptVersion   String?
  errorMessage    String?
  outputUrl       String?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@map("dog_avatar_generation_jobs")
}

model DogAvatarStateHistory {
  id                    String   @id @default(cuid())
  dogId                 String
  avatarState           String
  triggerReason         String?
  linkedActivityId      String?
  linkedNotificationId  String?
  timestamp             DateTime @default(now())

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@map("dog_avatar_state_history")
}

model DogIssue {
  id        String   @id @default(cuid())
  dogId     String
  issue     String
  createdAt DateTime @default(now())

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@unique([dogId, issue])
  @@map("dog_issues")
}

// ─── BREED SELECTION ─────────────────────────────────────────────────────────

model BreedSelectionProfile {
  id                String   @id @default(cuid())
  userId            String
  lifestyle         String?
  homeType          String?
  experienceLevel   String?
  availableTime     String?
  hasChildren       Boolean?
  goal              String?
  sizePreference    String?
  weightPreference  String?
  coatType          String?
  groomingTolerance String?
  noiseTolerance    String?
  energyExpectation String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  breedRecommendations BreedRecommendation[]

  @@map("breed_selection_profiles")
}

model BreedRecommendation {
  id                   String   @id @default(cuid())
  selectionProfileId   String
  breedName            String
  breedDescription     String
  reason               String
  rank                 Int      @default(1)
  createdAt            DateTime @default(now())

  selectionProfile BreedSelectionProfile @relation(fields: [selectionProfileId], references: [id], onDelete: Cascade)

  @@map("breed_recommendations")
}

// ─── TRAINING PLANS & TASKS ──────────────────────────────────────────────────

model TrainingPlan {
  id           String   @id @default(cuid())
  userId       String
  dogId        String?
  title        String
  planType     String
  goal         String
  weeklyFocus  String
  tips         String[]
  startDate    DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lastAdaptedAt    DateTime?          // when adaptation engine last modified this plan
  skippedTaskCount Int       @default(0) // rolling count of skipped/ignored tasks
  simplifiedAt     DateTime?          // set when user accepts "simpler plan" offer

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  dog   Dog?         @relation(fields: [dogId], references: [id], onDelete: SetNull)
  tasks TrainingTask[]

  @@map("training_plans")
}

model TrainingTask {
  id              String   @id @default(cuid())
  planId          String
  title           String
  description     String
  category        String
  difficulty      Int
  expectedOutcome String
  status          String   @default("pending")
  scheduledDay    Int
  notes           String   @default("")
  guidanceNote    String?  // set by adaptation engine when difficulty is reduced
  updatedAt       DateTime @updatedAt

  plan     TrainingPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  feedback TaskFeedback[]

  @@map("training_tasks")
}

model TaskFeedback {
  id               String   @id @default(cuid())
  taskId           String
  dogId            String?
  result           String
  timingNote       String?
  situationNote    String?
  dogBehaviorNote  String?
  freeText         String?
  createdAt        DateTime @default(now())

  task       TrainingTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  dog        Dog?          @relation(fields: [dogId], references: [id], onDelete: SetNull)
  adjustment AiAdjustment?

  @@map("task_feedback")
}

model AiAdjustment {
  id               String   @id @default(cuid())
  feedbackId       String   @unique
  probableCause    String
  probableMistake  String
  doNow            String[]
  avoid            String[]
  nextAttempt      String
  createdAt        DateTime @default(now())

  feedback TaskFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@map("ai_adjustments")
}

// ─── DAILY LOGS ──────────────────────────────────────────────────────────────

model DailyLog {
  id        String   @id @default(cuid())
  dogId     String
  logDate   DateTime @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dog              Dog                  @relation(fields: [dogId], references: [id], onDelete: Cascade)
  feedingLogs      FeedingLog[]
  walkLogs         WalkLog[]
  playLogs         PlayLog[]
  trainingLogs     TrainingSessionLog[]
  toiletEvents     ToiletEvent[]
  behaviorEvents   BehaviorEvent[]

  @@unique([dogId, logDate])
  @@map("daily_logs")
}

model FeedingLog {
  id            String   @id @default(cuid())
  dailyLogId    String
  dogId         String
  loggedAt      DateTime
  foodType      String?
  feedingNumber Int?
  durationMin   Int?
  notes         String   @default("")
  createdAt     DateTime @default(now())

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  dog      Dog      @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@map("feeding_logs")
}

model WalkLog {
  id          String   @id @default(cuid())
  dailyLogId  String
  dogId       String
  loggedAt    DateTime
  durationMin Int
  distanceKm  Decimal? @db.Decimal(5, 2)
  walkQuality String?
  stepCount   Int?
  notes       String   @default("")
  createdAt   DateTime @default(now())

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  dog      Dog      @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@map("walk_logs")
}

model PlayLog {
  id           String   @id @default(cuid())
  dailyLogId   String
  dogId        String
  loggedAt     DateTime
  durationMin  Int
  playActivity String?
  notes        String   @default("")
  createdAt    DateTime @default(now())

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  dog      Dog      @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@map("play_logs")
}

model TrainingSessionLog {
  id          String   @id @default(cuid())
  dailyLogId  String
  dogId       String
  loggedAt    DateTime
  durationMin Int
  notes       String   @default("")
  createdAt   DateTime @default(now())

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  dog      Dog      @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@map("training_session_logs")
}

model ToiletEvent {
  id                        String   @id @default(cuid())
  dogId                     String
  dailyLogId                String?
  occurredAt                DateTime
  outcome                   String
  minutesAfterLastFeeding   Int?
  minutesAfterLastSleep     Int?
  notes                     String   @default("")
  createdAt                 DateTime @default(now())

  dog      Dog       @relation(fields: [dogId], references: [id], onDelete: Cascade)
  dailyLog DailyLog? @relation(fields: [dailyLogId], references: [id], onDelete: SetNull)

  @@map("toilet_events")
}

// ─── BEHAVIOR EVENTS ─────────────────────────────────────────────────────────

model BehaviorEvent {
  id           String   @id @default(cuid())
  dogId        String
  dailyLogId   String?
  activityType String?
  notes        String   @default("")
  occurredAt   DateTime
  createdAt    DateTime @default(now())

  dog      Dog                  @relation(fields: [dogId], references: [id], onDelete: Cascade)
  dailyLog DailyLog?            @relation(fields: [dailyLogId], references: [id], onDelete: SetNull)
  issues   BehaviorEventIssue[]

  @@map("behavior_events")
}

model BehaviorEventIssue {
  eventId String
  issue   String

  event BehaviorEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([eventId, issue])
  @@map("behavior_event_issues")
}

// ─── NOTES & EXTRACTION ──────────────────────────────────────────────────────

model UserNote {
  id              String    @id @default(cuid())
  dogId           String
  sourceType      String
  sourceId        String?
  rawText         String
  isExtracted     Boolean   @default(false)
  extractionError String?
  createdAt       DateTime  @default(now())

  dog      Dog                   @relation(fields: [dogId], references: [id], onDelete: Cascade)
  signals  ExtractedNoteSignal[]

  @@map("user_notes")
}

model ExtractedNoteSignal {
  id             String   @id @default(cuid())
  noteId         String
  dogId          String
  signalType     String
  dimension      String?
  content        String
  sentimentScore Decimal? @db.Decimal(4, 3)
  confidence     Decimal? @db.Decimal(4, 3)
  createdAt      DateTime @default(now())

  note UserNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  dog  Dog      @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@map("extracted_note_signals")
}

// ─── BEHAVIOR SCORES & MEMORY ────────────────────────────────────────────────

model BehaviorDimension {
  id          String   @id @default(cuid())
  dogId       String
  dimension   String
  score       Decimal  @default(50) @db.Decimal(5, 2)
  trend       String   @default("stable")
  confidence  Decimal  @default(0) @db.Decimal(5, 2)
  lastUpdated DateTime @default(now())

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@unique([dogId, dimension])
  @@map("behavior_dimensions")
}

model BehaviorScoreHistory {
  id            String   @id @default(cuid())
  dogId         String
  dimension     String
  snapshotDate  DateTime @db.Date
  score         Decimal  @db.Decimal(5, 2)
  dailySignal   Decimal? @db.Decimal(5, 2)
  confidence    Decimal? @db.Decimal(5, 2)
  activityCount Int      @default(0)
  createdAt     DateTime @default(now())

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@unique([dogId, dimension, snapshotDate])
  @@map("behavior_score_history")
}

model DogMemory {
  id                    String    @id @default(cuid())
  dogId                 String    @unique
  currentFocusArea      String?
  currentStrengths      String[]
  currentWeakAreas      String[]
  recurringTriggers     String[]
  whatWorked            String[]
  whatFailed            String[]
  recentIssuesSummary   String?
  recentWinsSummary     String?
  aiContextSnapshot     String?
  snapshotGeneratedAt   DateTime?
  totalSessionsLogged   Int       @default(0)
  totalNotesProcessed   Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@map("dog_memory")
}

model RecurringTrigger {
  id               String   @id @default(cuid())
  dogId            String
  triggerPattern   String
  activityContext  String?
  occurrenceCount  Int      @default(1)
  firstSeen        DateTime @default(now())
  lastSeen         DateTime @default(now())
  isResolved       Boolean  @default(false)

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@unique([dogId, triggerPattern])
  @@map("recurring_triggers")
}

// ─── AI CONVERSATIONS ────────────────────────────────────────────────────────

model AiConversation {
  id            String   @id @default(cuid())
  userId        String
  dogId         String?
  createdAt     DateTime @default(now())
  lastMessageAt DateTime @default(now())

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@map("ai_conversations")
}

model AiMessage {
  id               String   @id @default(cuid())
  conversationId   String
  role             String
  content          String
  promptVersionId  String?
  modelUsed        String?  // which model generated this response
  tokensUsed       Int?
  latencyMs        Int?
  createdAt        DateTime @default(now())

  conversation  AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  promptVersion PromptVersion? @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)

  @@map("ai_messages")
}

model AiAdviceHistory {
  id          String   @id @default(cuid())
  dogId       String
  adviceType  String
  adviceText  String
  wasHelpful  Boolean?
  createdAt   DateTime @default(now())

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@map("ai_advice_history")
}

model DailyInsight {
  id             String   @id @default(cuid())
  dogId          String
  insightDate    DateTime @db.Date
  insightText    String
  dimensionFocus String?
  scoreDelta     Decimal? @db.Decimal(5, 2)
  createdAt      DateTime @default(now())

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@unique([dogId, insightDate])
  @@map("daily_insights")
}

model ShareSummary {
  id             String    @id @default(cuid())
  dogId          String
  summaryText    String
  shareUrlToken  String    @unique @default(cuid())
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@map("share_summaries")
}

// ─── SUBSCRIPTIONS ───────────────────────────────────────────────────────────

model Subscription {
  id                  String    @id @default(cuid())
  userId              String    @unique
  tier                String    @default("free")
  platform            String?
  storeProductId      String?
  storeTransactionId  String?
  storeOriginalTxId   String?
  expiresAt           DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model SubscriptionEvent {
  id                     String   @id @default(cuid())
  userId                 String
  eventType              String
  tierBefore             String?
  tierAfter              String?
  storeNotificationRaw   Json?
  createdAt              DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscription_events")
}

model AiUsage {
  id                   String   @id @default(cuid())
  userId               String
  usageDate            DateTime @db.Date
  requestCount         Int      @default(0)
  tokenCount           Int      @default(0)
  advancedRequestCount Int      @default(0)  // gpt-5.5 requests — for cost tracking
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, usageDate])
  @@map("ai_usage")
}

// ─── FUTURE DOG MODE ─────────────────────────────────────────────────────────

model FutureDogProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  dogName          String?                          // user-chosen name for their future dog
  preferredBreed   String?
  lifestyle        String    @default("moderate")  // active | moderate | calm
  homeType         String    @default("apartment")  // apartment | house_small | house_large | rural
  timeAvailability String    @default("moderate")   // low | moderate | high
  expectedSize     String?                          // small | medium | large
  preparationStage String    @default("exploring")  // exploring | committed | ready
  avatarUrl        String?                          // AI-generated portrait URL
  transformedAt    DateTime?                        // set when user gets real dog — profile is kept for AI context
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningProfile   UserLearningProfile?
  simulationSessions SimulationSession[]

  @@map("future_dog_profiles")
}

model UserLearningProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  futureDogProfileId   String   @unique
  decisionsAnalyzed    Int      @default(0)
  scenariosCompleted   Int      @default(0)
  consistencyScore     Decimal  @default(0) @db.Decimal(5, 2)
  knownStrengths       String[]
  knownGaps            String[]
  reactionTendencies   String[]
  overallReadinessScore Decimal @default(0) @db.Decimal(5, 2)
  lastUpdatedAt        DateTime @default(now())

  futureDogProfile FutureDogProfile @relation(fields: [futureDogProfileId], references: [id], onDelete: Cascade)

  @@map("user_learning_profiles")
}

model SimulationSession {
  id                  String    @id @default(cuid())
  userId              String
  futureDogProfileId  String
  category            String    // first_walk | home_arrival | feeding | socialization | evening_calm
  title               String
  description         String    @db.Text
  userResponse        String?   @db.Text
  aiEvaluation        String?   @db.Text
  correctApproach     String?   @db.Text
  whatUnderstood      String?
  whatToImprove       String?
  score               Int?      // 0–100
  completed           Boolean   @default(false)
  createdAt           DateTime  @default(now())
  completedAt         DateTime?

  futureDogProfile FutureDogProfile @relation(fields: [futureDogProfileId], references: [id], onDelete: Cascade)

  @@map("simulation_sessions")
}

// ─── REFERRALS ───────────────────────────────────────────────────────────────

model Referral {
  id              String    @id @default(cuid())
  referrerId      String
  referredId      String?   @unique
  status          String    @default("registered") // registered | subscribed | rewarded
  rewardGranted   Boolean   @default(false)
  ipAddressHash   String?
  createdAt       DateTime  @default(now())
  subscribedAt    DateTime?

  referrer User            @relation("ReferrerRelation", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User?           @relation("ReferredRelation", fields: [referredId], references: [id], onDelete: SetNull)
  rewards  ReferralReward[]

  @@map("referrals")
}

model ReferralReward {
  id          String   @id @default(cuid())
  referralId  String
  userId      String
  rewardType  String
  rewardValue Int
  grantedAt   DateTime @default(now())

  referral Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("referral_rewards")
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────────────

model NotificationToken {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  platform   String   @default("ios")
  deviceName String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  lastSeen   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_tokens")
}

model NotificationJob {
  id            String    @id @default(cuid())
  userId        String
  dogId         String?
  jobType       String
  scheduledFor  DateTime
  sentAt        DateTime?
  failedAt      DateTime?
  errorMessage  String?
  payload       Json      @default("{}")
  createdAt     DateTime  @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  dog  Dog?  @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@map("notification_jobs")
}

// ─── GAMIFICATION ────────────────────────────────────────────────────────────

model UserProgress {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  totalPoints               Int      @default(0)
  currentStreak             Int      @default(0)
  longestStreak             Int      @default(0)
  lastActiveDate            DateTime? @db.Date
  level                     String   @default("beginner")
  consecutiveSuccessCount   Int      @default(0)
  consecutiveNoIssuesCount  Int      @default(0)
  updatedAt                 DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_progress")
}

model Challenge {
  id            String  @id @default(cuid())
  challengeType String  @unique
  title         String
  description   String
  icon          String
  requirement   Int
  pointReward   Int
  requiresDog   Boolean @default(true)

  userChallenges UserChallenge[]

  @@map("challenges")
}

model UserChallenge {
  id          String    @id @default(cuid())
  userId      String
  challengeId String
  progress    Int       @default(0)
  isCompleted Boolean   @default(false)
  completedAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id])

  @@unique([userId, challengeId])
  @@map("user_challenges")
}

// ─── ADAPTIVE PATTERNS ───────────────────────────────────────────────────────

model AdaptivePattern {
  id                      String    @id @default(cuid())
  dogId                   String    @unique
  toiletAfterSleepMin     Decimal?  @db.Decimal(6, 2)
  toiletAfterFeedingMin   Decimal?  @db.Decimal(6, 2)
  trainingFatigueMin      Decimal?  @db.Decimal(6, 2)
  activityFatigueMin      Decimal?  @db.Decimal(6, 2)
  sampleCount             Int       @default(0)
  lastLearnedAt           DateTime?
  updatedAt               DateTime  @updatedAt

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@map("adaptive_patterns")
}

// ─── DAILY ROUTINES ──────────────────────────────────────────────────────────

model DailyRoutine {
  id          String   @id @default(cuid())
  dogId       String
  routineDate DateTime @db.Date
  generatedAt DateTime @default(now())

  dog    Dog            @relation(fields: [dogId], references: [id], onDelete: Cascade)
  cycles RoutineCycle[]

  @@unique([dogId, routineDate])
  @@map("daily_routines")
}

model RoutineCycle {
  id                   String    @id @default(cuid())
  routineId            String
  cycleNumber          Int
  phase                String
  suggestedTime        DateTime
  expectedDurationMin  Int
  isCompleted          Boolean   @default(false)
  completedAt          DateTime?
  linkedActivityId     String?
  skipped              Boolean   @default(false)

  routine DailyRoutine @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@unique([routineId, cycleNumber, phase])
  @@map("routine_cycles")
}

// ─── PROMPT VERSIONING ───────────────────────────────────────────────────────

model PromptVersion {
  id         String   @id @default(cuid())
  name       String
  promptType String
  version    String
  content    String
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())

  messages AiMessage[]

  @@unique([name, version])
  @@map("prompt_versions")
}

// ─── AUDIT LOGS ──────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model ErrorLog {
  id           String   @id @default(cuid())
  service      String
  errorCode    String?
  errorMessage String
  stackTrace   String?
  requestId    String?
  userId       String?
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())

  @@map("error_logs")
}
